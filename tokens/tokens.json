{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",

  "color": {
    "$type": "color",

    "primary": {
      "base": {
        "$value": { "colorSpace": "srgb", "components": [0.98, 0.882, 0.153], "hex": "#fae127" }
      },
      "hover": {
        "$value": { "colorSpace": "srgb", "components": [0.973, 0.886, 0.243], "hex": "#f8e23e" }
      },
      "muted": {
        "$value": { "colorSpace": "srgb", "components": [0.98, 0.882, 0.153], "alpha": 0.1, "hex": "#fae127" }
      },
      "glow": {
        "$value": { "colorSpace": "srgb", "components": [0.98, 0.882, 0.153], "alpha": 0.4, "hex": "#fae127" }
      }
    },

    "secondary": {
      "base": {
        "$value": { "colorSpace": "srgb", "components": [0.169, 0.929, 0.929], "hex": "#2beded" }
      },
      "hover": {
        "$value": { "colorSpace": "srgb", "components": [0.361, 0.945, 0.945], "hex": "#5cf1f1" }
      },
      "muted": {
        "$value": { "colorSpace": "srgb", "components": [0.169, 0.929, 0.929], "alpha": 0.1, "hex": "#2beded" }
      },
      "glow": {
        "$value": { "colorSpace": "srgb", "components": [0.169, 0.929, 0.929], "alpha": 0.4, "hex": "#2beded" }
      }
    },

    "dark": {
      "900": {
        "$value": { "colorSpace": "srgb", "components": [0.082, 0.11, 0.122], "hex": "#151c1f" }
      },
      "800": {
        "$value": { "colorSpace": "srgb", "components": [0.11, 0.141, 0.157], "hex": "#1c2428" }
      },
      "700": {
        "$value": { "colorSpace": "srgb", "components": [0.137, 0.176, 0.196], "hex": "#232d32" }
      },
      "600": {
        "$value": { "colorSpace": "srgb", "components": [0.165, 0.212, 0.235], "hex": "#2a363c" }
      },
      "500": {
        "$value": { "colorSpace": "srgb", "components": [0.216, 0.275, 0.306], "hex": "#37464e" }
      }
    },

    "text": {
      "primary": {
        "$value": { "colorSpace": "srgb", "components": [1, 1, 1], "hex": "#ffffff" }
      },
      "secondary": {
        "$value": { "colorSpace": "srgb", "components": [1, 1, 1], "alpha": 0.7, "hex": "#ffffff" }
      },
      "muted": {
        "$value": { "colorSpace": "srgb", "components": [1, 1, 1], "alpha": 0.5, "hex": "#ffffff" }
      }
    },

    "border": {
      "default": {
        "$value": { "colorSpace": "srgb", "components": [1, 1, 1], "alpha": 0.1, "hex": "#ffffff" }
      },
      "hover": {
        "$value": { "colorSpace": "srgb", "components": [1, 1, 1], "alpha": 0.2, "hex": "#ffffff" }
      }
    },

    "semantic": {
      "success": {
        "$value": { "colorSpace": "srgb", "components": [0.133, 0.773, 0.369], "hex": "#22c55e" }
      },
      "warning": {
        "$value": { "colorSpace": "srgb", "components": [0.961, 0.62, 0.043], "hex": "#f59e0b" }
      },
      "error": {
        "$value": { "colorSpace": "srgb", "components": [0.937, 0.267, 0.267], "hex": "#ef4444" }
      }
    }
  },

  "font": {
    "$type": "fontFamily",

    "display": {
      "$value": ["Space Grotesk", "system-ui", "sans-serif"]
    },
    "body": {
      "$value": ["Inter", "system-ui", "sans-serif"]
    },
    "mono": {
      "$value": ["JetBrains Mono", "monospace"]
    }
  },

  "duration": {
    "$type": "duration",

    "glow-pulse": {
      "$value": { "value": 2000, "unit": "ms" }
    },
    "slide-up": {
      "$value": { "value": 500, "unit": "ms" }
    },
    "fade-in": {
      "$value": { "value": 300, "unit": "ms" }
    },
    "float": {
      "$value": { "value": 6000, "unit": "ms" }
    },
    "scan-line": {
      "$value": { "value": 8000, "unit": "ms" }
    },
    "marquee": {
      "$value": { "value": 30000, "unit": "ms" }
    }
  }
}
