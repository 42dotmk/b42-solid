# ===========================================
# Base42 Website - Environment Variables
# ===========================================
# Copy to .env and fill in values

# --- Medusa Backend ---
# URL where the Medusa API is accessible
# For local dev with docker-compose.dev.yml: http://localhost:9000
# For production docker-compose: http://medusa:9000 (internal)
VITE_MEDUSA_BACKEND_URL=http://localhost:9000
MEDUSA_BACKEND_URL=http://localhost:9000

# Publishable API key from Medusa Admin > Settings > Publishable API Keys
# Required for all store API requests
VITE_MEDUSA_PUBLISHABLE_KEY=
MEDUSA_PUBLISHABLE_KEY=

# Medusa region ID (create in Medusa Admin > Settings > Regions)
# Used for product pricing and cart creation
VITE_MEDUSA_REGION_ID=
MEDUSA_REGION_ID=

# --- Database (production docker-compose only) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=medusa-store

# --- Auth Secrets (production) ---
JWT_SECRET=change-me-in-production
COOKIE_SECRET=change-me-in-production

# --- CORS (production) ---
STORE_CORS=https://42.mk
ADMIN_CORS=https://admin.42.mk
AUTH_CORS=https://42.mk,https://admin.42.mk

# --- Stripe ---
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Site ---
SITE_URL=https://42.mk

# --- YouTube ---
VITE_PUBLIC_YOUTUBE_CHANNEL_ID=UC4pYLpC8chMP4IVrkwMCX1g
YOUTUBE_API_KEY=

# --- Strapi (events, non-shop content) ---
VITE_PUBLIC_STRAPI_URL=https://cms.42.mk

# --- Docker Ports (production) ---
MEDUSA_PORT=9000
WEB_PORT=3000
MEDUSA_PUBLIC_URL=https://api.42.mk
MEDUSA_PUBLISHABLE_KEY=
