# Database
DATABASE_URL=postgres://postgres:postgres@postgres:5432/medusa-store

# Redis
REDIS_URL=redis://redis:6379

# Auth secrets (CHANGE IN PRODUCTION)
JWT_SECRET=your-jwt-secret-here
COOKIE_SECRET=your-cookie-secret-here

# CORS - set to your storefront URL
STORE_CORS=http://localhost:5173
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000

# Medusa
MEDUSA_BACKEND_URL=http://localhost:9000

# Stripe (optional - configure in Medusa admin)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# Worker mode: shared (default), server, or worker
# MEDUSA_WORKER_MODE=shared
# DISABLE_MEDUSA_ADMIN=false
